# ============================================================================
#  api_client.py  —  Data-fetching layer for the recipe explorer application
# ----------------------------------------------------------------------------
#
#  PURPOSE
#  -------
#  This module is the single point of contact between the Streamlit UI and the
#  two external recipe/nutrition APIs the app relies on:
#
#    1. TheMealDB  (https://www.themealdb.com/api.php)
#       A free, public recipe database.  No API key required.
#       Used for: recipe search, cuisine (area) listing, meal detail lookup,
#       ingredient catalogue, and cuisine-filtered browsing.
#
#    2. Spoonacular  (https://spoonacular.com/food-api)
#       A freemium recipe + nutrition API.  Requires an API key stored in
#       Streamlit's secrets manager under the key "SPOONACULAR_API_KEY".
#       Used for: per-serving nutrition data and diet-filtered recipe search.
#
#  DESIGN NOTES
#  ------------
#  • Every public function is decorated with @st.cache_data so that repeated
#    calls (e.g., on every Streamlit re-render) do NOT fire new HTTP requests.
#    TTL values are tuned to the volatility of the data:
#      - 1 hour  for data that may change during a user session (search results,
#        cuisine filters, single-meal lookups, nutrition by ingredients)
#      - 24 hours for near-static reference data (cuisine list, ingredient
#        catalogue, nutrition by dish title)
#
#  • All network calls use a 20-second timeout and are wrapped in
#    try/except so that API failures degrade gracefully (empty list / None)
#    rather than crashing the UI.
#
#  • The _area_name_variants() helper was written with AI assistance to handle
#    the linguistic mismatch between TheMealDB's /list endpoint (which uses
#    adjectival demonyms like "Indonesian") and its /filter endpoint (which
#    sometimes only accepts plain country names like "Indonesia").  The curated
#    mapping dictionary inside it was generated and reviewed with AI help.
#
#  DEPENDENCIES
#  ------------
#  External packages (must be installed in the project environment):
#    - requests      HTTP client used for all API calls
#    - streamlit     Web-app framework; also provides caching (@st.cache_data)
#                    and secrets management (st.secrets)
#
#  Standard-library modules imported inline:
#    - re            Used in search_spoonacular() to strip HTML tags from
#                    Spoonacular's summary field
#
#  External services:
#    - TheMealDB API  (free, no auth)  https://www.themealdb.com/api/json/v1/1
#    - Spoonacular API (needs key)     https://api.spoonacular.com
#
# ============================================================================

import requests
import streamlit as st

# Base URL for all TheMealDB v1 endpoints.
# TheMealDB offers a free tier at path /api/json/v1/1 with no authentication.
THEMEALDB_BASE = "https://www.themealdb.com/api/json/v1/1"


# ---------------------------------------------------------------------------
# TheMealDB helpers
# ---------------------------------------------------------------------------

@st.cache_data(ttl=60 * 60)   # Cache results for 1 hour to avoid hammering the API
def search_recipes_by_name(query: str) -> list[dict]:
    """Search TheMealDB for recipes whose name contains `query`.

    Returns a list of full meal dicts (each containing name, ingredients,
    instructions, thumbnail URL, etc.).  Returns an empty list if the
    network call fails or no results are found.

    Args:
        query: Free-text search string, e.g. "pasta" or "chicken curry".

    Returns:
        List of TheMealDB meal dicts, or [] on failure / no results.
    """
    try:
        resp = requests.get(
            f"{THEMEALDB_BASE}/search.php", params={"s": query}, timeout=20
        )
        resp.raise_for_status()   # Raises HTTPError for 4xx / 5xx responses
        # TheMealDB returns {"meals": [...]} on success, {"meals": null} when
        # nothing is found — the "or []" handles the null case.
        return resp.json().get("meals") or []
    except requests.RequestException as exc:
        # Show a non-fatal warning in the Streamlit sidebar; don't crash the app
        st.warning(f"Recipe search unavailable: {exc}")
        return []


@st.cache_data(ttl=24 * 60 * 60)   # Cache for 24 hours; cuisine list rarely changes
def list_cuisines() -> list[str]:
    """Return the raw list of cuisine names from TheMealDB (called 'areas').

    TheMealDB uses the word "area" internally for what most users call a
    "cuisine" or "country".  This function returns all ~200 area names that
    TheMealDB knows about, regardless of whether they actually have recipes.
    See list_cuisines_with_recipes() for a filtered version.

    Returns:
        Sorted list of area/cuisine name strings, e.g. ["British", "Chinese",
        "French", ...].  Returns [] if the API is unreachable.
    """
    try:
        resp = requests.get(
            f"{THEMEALDB_BASE}/list.php", params={"a": "list"}, timeout=20
        )
        resp.raise_for_status()
        # Each dict in the "meals" list has a single key: "strArea"
        return [m["strArea"] for m in (resp.json().get("meals") or [])]
    except requests.RequestException:
        return []


@st.cache_data(ttl=24 * 60 * 60)   # Expensive (makes many sub-requests); cache 24 h
def list_cuisines_with_recipes() -> list[str]:
    """Return only cuisine names that actually have at least one recipe.

    TheMealDB's /list endpoint returns ~200 area names but many of them return
    zero results when queried via the /filter endpoint (e.g. "Peruvian",
    "Indonesian").  This function probes each area and returns only the ones
    that produce real recipe stubs.

    This is intentionally slow on first call (it fires N sub-requests where N
    is the number of areas) but is cached for 24 hours so subsequent renders
    are instant.  The result is used by the world-map page so that only
    countries with actual recipes are made clickable.

    Returns:
        List of cuisine name strings that have at least one recipe in the DB.
    """
    all_areas = list_cuisines()
    valid = []
    for area in all_areas:
        meals = filter_by_cuisine(area)   # Returns [] if no results for this area
        if meals:
            valid.append(area)
    return valid


def _area_name_variants(area: str) -> list[str]:
    """Generate candidate area/cuisine name strings to try with TheMealDB's filter.

    NOTE: This function has no @st.cache_data because it is pure string
    manipulation with no I/O.  It is called inside the cached filter_by_cuisine().

    BACKGROUND (AI-assisted design):
    TheMealDB's /list endpoint returns adjectival demonyms ("Indonesian",
    "Argentine") but its /filter endpoint sometimes only accepts the plain
    country name ("Indonesia", "Argentina") — or vice versa.  Rather than
    maintaining a static alias table that breaks whenever TheMealDB adds new
    areas, this function generates plausible name variants automatically and
    lets filter_by_cuisine() try each one in turn, stopping at the first hit.
    The large _AREA_TO_COUNTRY mapping below was generated with AI assistance
    and then manually reviewed for accuracy.

    Args:
        area: The area name as returned by TheMealDB's /list endpoint.


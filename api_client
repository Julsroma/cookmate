@st.cache_data(ttl=60 * 60)   # Cache 1 hour; recipe lists change occasionally
def filter_by_cuisine(cuisine: str) -> list[dict]:
    """Return lightweight recipe stubs for a given cuisine name.

    Each stub contains only the meal ID, name, and thumbnail URL — NOT the
    full ingredient/instruction data.  Use get_meal_by_id() to hydrate a stub
    into a full meal dict.

    This function transparently handles TheMealDB's inconsistent area naming
    by delegating to _area_name_variants() and trying each candidate name in
    order until one returns results.

    Args:
        cuisine: Area/cuisine name, in any form TheMealDB might accept
                 (e.g. "Indonesian", "Indonesia", "British", etc.).

    Returns:
        List of lightweight meal dicts with keys: idMeal, strMeal,
        strMealThumb.  Returns [] if no results found or on network error.
    """
    for candidate in _area_name_variants(cuisine):
        try:
            resp = requests.get(
                f"{THEMEALDB_BASE}/filter.php", params={"a": candidate}, timeout=20
            )
            resp.raise_for_status()
            meals = resp.json().get("meals") or []
            if meals:
                # Found results for this name variant — stop trying further candidates
                return meals
        except requests.RequestException:
            # Network error: bail out immediately rather than retrying other variants
            return []
    return []   # All name variants exhausted with no results


@st.cache_data(ttl=60 * 60)   # Cache 1 hour; individual meal data is stable
def get_meal_by_id(meal_id: str) -> dict | None:
    """Fetch the full detail record for a single meal from TheMealDB.

    Args:
        meal_id: The TheMealDB numeric meal ID as a string (e.g. "52772").

    Returns:
        Full meal dict with all 20 ingredient/measure fields, instructions,
        YouTube link, tags, etc.  Returns None if not found or on error.
    """
    try:
        resp = requests.get(
            f"{THEMEALDB_BASE}/lookup.php", params={"i": meal_id}, timeout=20
        )
        resp.raise_for_status()
        meals = resp.json().get("meals") or []
        # The lookup endpoint returns a list but always has 0 or 1 items
        return meals[0] if meals else None
    except requests.RequestException:
        return None


@st.cache_data(ttl=60 * 60)   # Cache 1 hour — the combined fetch can be slow
def fetch_cuisine_meals(cuisine: str, limit: int = 10) -> list[dict]:
    """Return full meal dicts for a cuisine, batched and cached in one call.

    PERFORMANCE NOTE: Earlier versions of this function were called without
    caching from the Recipes page, triggering up to 10 sequential HTTP
    requests on every Streamlit re-render.  By moving the full fetch logic
    here under @st.cache_data, subsequent renders within the 1-hour window
    cost zero network calls.

    This function combines filter_by_cuisine() (which returns stubs) and
    get_meal_by_id() (which hydrates each stub) so callers get full meal
    dicts in a single cached operation.

    Args:
        cuisine: Area/cuisine name passed to filter_by_cuisine().
        limit:   Max number of meals to return (default 10).

    Returns:
        List of full meal dicts (up to `limit` items).  Items where
        get_meal_by_id() returns None are silently skipped.
    """
    stubs = filter_by_cuisine(cuisine)[:limit]
    # Walrus operator (:=) fetches and assigns in one expression;
    # the conditional filters out any stubs whose lookup returned None.
    return [m for stub in stubs if (m := get_meal_by_id(stub["idMeal"]))]


# ---------------------------------------------------------------------------
# Ingredient extraction
# ---------------------------------------------------------------------------

def extract_ingredients_from_meal(meal: dict) -> list[str]:
    """Parse the ingredient and measure fields out of a TheMealDB meal dict.

    TheMealDB stores ingredients in 20 parallel numbered fields:
      strIngredient1 … strIngredient20
      strMeasure1    … strMeasure20
    Fields beyond the last ingredient are empty strings or None.

    Returns a list like ["2 cups flour", "1 tsp salt", "egg"] where the
    measure is prepended when present.

    Args:
        meal: A full TheMealDB meal dict (as returned by get_meal_by_id()).

    Returns:
        List of "measure ingredient" strings.  Empty/null fields are skipped.
    """
    ingredients = []
    for i in range(1, 21):   # TheMealDB has exactly 20 ingredient slots
        name    = (meal.get(f"strIngredient{i}") or "").strip()
        measure = (meal.get(f"strMeasure{i}")    or "").strip()
        if name:
            # Combine measure + name when a measure is present (e.g. "2 cups flour")
            # or use just the name when it isn't (e.g. "salt")
            ingredients.append(f"{measure} {name}".strip() if measure else name)
    return ingredients


@st.cache_data(ttl=24 * 60 * 60)   # Cache 24 h; ingredient catalogue rarely changes
def get_themealdb_ingredients() -> list[str]:
    """Fetch the complete ingredient catalogue from TheMealDB, sorted A–Z.

    WHY THIS INSTEAD OF SPOONACULAR?
    Spoonacular's ingredient list is paid and quota-limited.  TheMealDB
    provides a free ingredient list whose names exactly match those used in
    TheMealDB recipes — so pantry searches and ingredient matching work
    without any name-normalisation step.

    Returns:
        Alphabetically sorted list of lowercase ingredient name strings.
        Returns [] if the API is unreachable (pantry feature still works,
        just without autocomplete suggestions).
    """
    try:
        resp = requests.get(
            f"{THEMEALDB_BASE}/list.php",
            params={"i": "list"},
            timeout=20,
        )
        resp.raise_for_status()
        meals = resp.json().get("meals") or []
        # Normalise to lowercase and sort alphabetically so the UI list is
        # consistent regardless of how TheMealDB capitalises the names.
        return sorted(
            m["strIngredient"].strip().lower()
            for m in meals
            if (m.get("strIngredient") or "").strip()   # Skip empty/null entries
        )
    except requests.RequestException:
        return []



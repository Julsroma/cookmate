def render_meal_card(
    meal: dict,
    ml_score: float | None = None,
    pantry: float | None = None,
    card_key: str = "",
) -> None:
    """Render a single recipe card with image, metadata, and action buttons.

    Each card shows:
      • Thumbnail image + dish name + cuisine/category
      • Optional ML match-score progress bar (when taste profile exists)
      • Optional pantry-availability badge (green/yellow)
      • Expandable ingredients & instructions section
      • ⭐ MEAL PLANNER: "➕ Add to Meal Planner" / "❌ Remove" toggle button

    Parameters
    ----------
    meal     : dict           Recipe dict (TheMealDB or Spoonacular schema).
    ml_score : float | None   Recommender score in [0,1]; None = not scored.
    pantry   : float | None   Fraction of ingredients in pantry; None = unknown.
    card_key : str            Unique prefix for all widget keys in this card
                              (e.g. "search_0", "cuisine_3"). MUST be unique
                              across every card rendered in a single Streamlit run
                              to avoid DuplicateWidgetID errors.
    """
    meal_title = meal["strMeal"]   # Both schemas expose a "strMeal" key via api_client normalisation

    with st.container(border=True):
        col_img, col_meta = st.columns([1, 3])   # Image gets 25% width, metadata 75%

        with col_img:
            st.image(meal.get("strMealThumb"), use_container_width=True)

        with col_meta:
            st.subheader(meal_title)
            # Area = cuisine origin (e.g. "Italian"); Category = dish type (e.g. "Pasta")
            st.caption(
                f"{meal.get('strArea', '—')} · {meal.get('strCategory', '—')}"
            )

            # ── ML match score (Req. 5) ───────────────────────────────────
            # Only shown when the Recommender produced a valid score (i.e. the
            # user has a taste profile built from saved recipes).
            if ml_score is not None and not pd.isna(ml_score):
                st.progress(float(ml_score), text=f"Match score: {ml_score:.0%}")

            # ── Pantry badge ──────────────────────────────────────────────
            # Green  → user owns >60% of ingredients (likely no shopping needed).
            # Yellow → 30–60% available (partial shop required).
            # No badge → <30% or pantry data unavailable.
            if pantry is not None:
                if pantry > 0.6:
                    st.success("🟢 Pantry-friendly")
                elif pantry > 0.3:
                    st.warning("🟡 Partially available")

            # ── Ingredients & Instructions (collapsible) ──────────────────
            with st.expander("🧾 Ingredients & Instructions"):
                col_ing, col_inst = st.columns([1, 2])
                with col_ing:
                    st.markdown("**Ingredients**")
                    for ing in extract_ingredients(meal):
                        st.markdown(f"- {ing}")
                with col_inst:
                    st.markdown("**Instructions**")
                    st.write(meal.get("strInstructions", "No instructions available."))

            # ══════════════════════════════════════════════════════════════
            # ⭐ MEAL PLANNER BUTTON LOGIC
            # This section connects the Recipes page to the Meal Planner.
            # ══════════════════════════════════════════════════════════════

            user_id  = st.session_state.get("user_id")

            # Step 1: Try to find this recipe's DB id from the static LOCAL_RECIPES list
            # (keyed by lowercase title for case-insensitive matching).
            local_id = local_title_to_id.get(meal_title.lower())

            # Step 2: If not found in the static list, check the `recipes` DB table
            # (the recipe may have been added dynamically during a previous session).
            if local_id is None:
                existing_recipe = query_df(
                    """
                    SELECT id FROM recipes
                    WHERE LOWER(title) = LOWER(?)
                    LIMIT 1
                    """,
                    (meal_title,),
                )
                if not existing_recipe.empty:
                    local_id = int(existing_recipe.iloc[0]["id"])

            # Step 3: Check whether this recipe is already in the user's planner_pool.
            # This determines which button variant to show (Add vs Remove).
            already_in_planner = False
            if user_id and local_id:
                planner_check = query_df(
                    """
                    SELECT 1 FROM planner_pool
                    WHERE user_id = ? AND recipe_id = ?
                    LIMIT 1
                    """,
                    (user_id, local_id),
                )
                already_in_planner = not planner_check.empty

            # ── Already saved: show a Remove button ───────────────────────
            if already_in_planner:
                st.success("🍽️ Already in your Meal Planner!")
                if st.button(
                    "❌ Remove from Meal Planner",
                    key=f"{card_key}_remove_planner_{meal_title}",
                ):
                    # ⭐ Delete from planner_pool removes the recipe from the
                    # Meal Planner page's dropdown options.
                    execute(
                        "DELETE FROM planner_pool WHERE user_id = ? AND recipe_id = ?",
                        (user_id, local_id),
                    )
                    # ⭐ Also delete any scheduled occurrences so the weekly
                    # grid in meal_planner.py doesn't show orphaned slots.
                    execute(
                        "DELETE FROM meal_plan WHERE user_id = ? AND recipe_id = ?",
                        (user_id, local_id),
                    )
                    st.toast(f"'{meal_title}' removed from Meal Planner 🗑️", icon="❌")
                    st.rerun()   # Refresh the card to flip from Remove → Add button

            # ── Not yet saved: show an Add button ─────────────────────────
            else:
                if st.button(
                    "➕ Add to Meal Planner",
                    key=f"{card_key}_planner_{meal_title}",
                ):
                    # ── Fetch nutrition before saving ─────────────────────
                    # _fetch_nutrition_robust() handles both Spoonacular recipes
                    # (nutrition already in the dict) and MealDB recipes (title
                    # lookup → ingredient-parser fallback). The values are
                    # persisted to the `recipes` table so the Recommender and
                    # Nutrition Analytics page can read them later.
                    nutrition = _fetch_nutrition_robust(meal)
                    kcal      = nutrition["kcal"]
                    protein_g = nutrition["protein_g"]
                    carbs_g   = nutrition["carbs_g"]
                    fat_g     = nutrition["fat_g"]

                    if local_id is None:
                        # ⭐ MEAL PLANNER — NEW RECIPE:
                        # This recipe came from the API and has never been saved before.
                        # Insert a new row into `recipes` so it gets a stable DB id,
                        # then capture that id for the planner_pool insert below.
                        execute(
                            """INSERT INTO recipes
                               (title, kcal_per_serv, protein_g, carbs_g, fat_g)
                               VALUES (?, ?, ?, ?, ?)""",
                            (meal_title, kcal, protein_g, carbs_g, fat_g),
                        )
                        # Retrieve the auto-generated id of the row we just inserted.
                        new_row = query_df(
                            "SELECT id FROM recipes WHERE title = ? ORDER BY id DESC LIMIT 1",
                            (meal_title,),
                        )
                        if not new_row.empty:
                            local_id = int(new_row.iloc[0]["id"])
                    else:
                        # ⭐ MEAL PLANNER — EXISTING RECIPE:
                        # Recipe already has a DB row. Update nutrition if we
                        # received fresh values (avoids overwriting with None).
                        if kcal is not None:
                            execute(
                                """UPDATE recipes
                                   SET kcal_per_serv = ?, protein_g = ?,
                                       carbs_g = ?, fat_g = ?
                                   WHERE id = ?""",
                                (kcal, protein_g, carbs_g, fat_g, local_id),
                            )

                    # ⭐ MEAL PLANNER — Add to planner_pool:
                    # INSERT OR IGNORE means clicking the button twice is safe
                    # (the row already exists, so the second insert is a no-op).
                    if local_id:
                        execute(
                            "INSERT OR IGNORE INTO planner_pool (user_id, recipe_id) VALUES (?, ?)",
                            (user_id, local_id),
                        )

                    # Store the title in session_state so the post-rerun toast
                    # (rendered at the top of this file) can display it after
                    # Streamlit re-renders the page from scratch.
                    st.session_state["planner_added_title"] = meal_title
                    st.rerun()



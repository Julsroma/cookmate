def get_my_planner_meals(user_id: int) -> list[dict]:
    """Fetch all recipes the current user has saved to their Meal Planner.

    ⭐ MEAL PLANNER: Reads the `planner_pool` table (the user's personal
    allow-list of pinned recipes) and joins it with `recipes` to get the title.
    This is the same data source that meal_planner.py uses to populate its
    weekly grid dropdowns.

    Parameters
    ----------
    user_id : int
        The logged-in user's database ID from st.session_state["user_id"].

    Returns
    -------
    list[dict]
        Each dict has 'recipe_id' (int) and 'title' (str).
        Returns an empty list if the user has no saved recipes or on any error.
    """
    if not user_id:
        return []
    try:
        df = query_df(
            """
            SELECT r.id AS recipe_id, r.title
            FROM planner_pool pp
            JOIN recipes r ON pp.recipe_id = r.id
            WHERE pp.user_id = ?
            ORDER BY r.title
            """,
            (user_id,),
        )
        if df.empty:
            return []
        return df.to_dict("records")
    except Exception:
        # DB errors (missing table, connection issues) return an empty list
        # so the UI degrades gracefully rather than crashing.
        return []


def show_my_planner_banner() -> None:
    """Render a collapsible summary of the user's saved Meal Planner dishes.

    Displayed at the very top of the Recipes page so users always know which
    recipes are already in their planner without navigating away.

    ⭐ MEAL PLANNER: Reads planner_pool via get_my_planner_meals() and renders
    a compact 3-column grid of saved dishes. The "✕" remove button on each
    dish deletes from BOTH `planner_pool` AND `meal_plan`, which keeps the
    Meal Planner page's weekly grid consistent (meal_planner.py won't show
    orphaned slots for recipes that no longer exist in the pool).

    Side effects
    ------------
    - Calls st.rerun() after any deletion so the banner refreshes immediately.
    - Writes nothing to the DB directly; delegated to execute().
    """
    user_id = st.session_state.get("user_id")
    if not user_id:
        return   # Not logged in — nothing to show

    saved_meals = get_my_planner_meals(user_id)
    count = len(saved_meals)
    label = "dish" if count == 1 else "dishes"   # Correct pluralisation

    # The expander is auto-expanded when the user has at least one saved dish
    with st.expander(
        f"🍽️ My Meal Planner  ·  **{count} {label} saved**",
        expanded=count > 0,
    ):
        if not saved_meals:
            st.info("You haven't saved any dishes to the Meal Planner yet.")
            return

        # 3-column grid: each cell shows the dish name + a remove button
        cols = st.columns(3)
        for idx, meal in enumerate(saved_meals):
            with cols[idx % 3]:   # Cycle through columns 0, 1, 2, 0, 1, 2 …
                col_text, col_btn = st.columns([3, 1])
                with col_text:
                    st.markdown(f"✅ **{meal['title']}**")
                with col_btn:
                    if st.button(
                        "✕",
                        key=f"banner_remove_{meal['recipe_id']}",  # Unique key per recipe
                        help="Remove from Meal Planner",
                    ):
                        # ⭐ MEAL PLANNER: Remove from the pool (hides it in
                        # planner dropdowns) AND from the scheduled grid rows.
                        execute(
                            "DELETE FROM planner_pool WHERE user_id = ? AND recipe_id = ?",
                            (user_id, meal["recipe_id"]),
                        )
                        execute(
                            "DELETE FROM meal_plan WHERE user_id = ? AND recipe_id = ?",
                            (user_id, meal["recipe_id"]),
                        )
                        st.toast(f"❌ '{meal['title']}' removed from Meal Planner", icon="🗑️")
                        st.rerun()   # Force banner to reflect the deletion immediately

        st.caption("Go to the **Meal Planner** page to schedule them across the week.")



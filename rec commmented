def get_pantry() -> set[str]:
    """Load the current user's pantry as a set of lowercase ingredient names.

    Reads from the `pantry` table (joined with `ingredients`) and filters to
    items where quantity > 0 (i.e. the user actually has the ingredient in stock).

    Returns
    -------
    set[str]
        Lowercase ingredient names, e.g. {"flour", "eggs", "olive oil"}.
        Empty set if the user is not logged in, has no pantry, or on DB error.
    """
    user_id = st.session_state.get("user_id")
    if not user_id:
        return set()
    try:
        df = query_df(
            """
            SELECT i.name
            FROM pantry p
            JOIN ingredients i ON p.ingredient_id = i.id
            WHERE p.user_id = ? AND p.quantity > 0
            """,
            (user_id,),
        )
        if df.empty:
            return set()
        return set(df["name"].str.lower())
    except Exception:
        return set()


def pantry_pct(meal: dict, pantry: set[str]) -> float | None:
    """Calculate what fraction of a recipe's ingredients the user already owns.

    Used in render_meal_card() to show a "Pantry-friendly" badge when the user
    can cook most of a dish without shopping.

    Parameters
    ----------
    meal   : dict    A recipe dict (any source).
    pantry : set[str] Lowercase ingredient names from get_pantry().

    Returns
    -------
    float in [0.0, 1.0], or None if pantry is empty or recipe has no ingredients.
    """
    if not pantry:
        return None
    ingredients = extract_ingredients(meal)
    if not ingredients:
        return None
    # Convert to lowercase for case-insensitive comparison against pantry set
    names = [i.lower() for i in ingredients]
    return sum(1 for n in names if n in pantry) / len(names)



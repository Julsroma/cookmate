with tab_search:
    st.subheader("🔎 Hungry? Let's find something delicious!")
    st.markdown("- Search for any dish by name")
    st.markdown("- Get info on the dish and how to make it")
    st.markdown("- Add it to your Meal Planner or Wishlist for later")

    # Primary search input — triggers a combined TheMealDB + Spoonacular query.
    query = st.text_input(
        "What would you like to cook?",
        placeholder="e.g. pasta, curry…",
    )

    if query:
        # ── Build diet/allergy filters from the user's profile ────────────────
        diet      = profile.get("diet", "omnivore")
        allergies = profile.get("allergies", [])

        # Derive boolean flags for Spoonacular's complexSearch parameters
        veg = diet in ("vegetarian", "vegan")
        vgn = diet == "vegan"
        gf  = "gluten" in allergies
        df  = "lactose" in allergies

        # ── Combined API search (Req. 2) ──────────────────────────────────────
        # TheMealDB doesn't support diet filters natively; Spoonacular does.
        # We merge both result sets and deduplicate in the Recommender step.
        results = search_recipes_by_name(query) + search_spoonacular(
            query=query,
            vegetarian=veg,
            vegan=vgn,
            gluten_free=gf,
            dairy_free=df,
        )

        if not results:
            empty_state("No recipes found — try another word.")
        else:
            # ── ML ranking (Req. 5) ───────────────────────────────────────────
            # Build a Recommender from the user's saved LOCAL_RECIPES data,
            # then score each search result by ingredient similarity.
            recipes_df = pd.DataFrame(LOCAL_RECIPES).rename(columns={"name": "title"})
            rec        = Recommender(recipes_df)

            # Only examine the top 10 results to keep scoring fast
            top_results = results[:10]

            # Pre-extract ingredient lists once (used by Recommender.score_external)
            ingredient_lists = [extract_ingredients(m) for m in top_results]

            # Score results if the user has a taste profile; otherwise return
            # a list of None scores so the sort below is a no-op.
            raw_scores = (
                rec.score_external(
                    ingredient_lists,
                    history_df,
                    wishlist_ids,
                    liked_ingredients,
                )
                if has_taste_profile
                else [None] * len(top_results)
            )

            # ── Sort: scored results first (descending score), then unscored ──
            # The lambda key produces a 2-tuple so Python's stable sort puts
            # all scored items (bucket 0) before unscored ones (bucket 1).
            scored_results = sorted(
                zip(top_results, raw_scores),
                key=lambda pair: (
                    (0, -(pair[1] or 0))   # Bucket 0: higher score sorts first
                    if pair[1] is not None
                    else (1, 0)            # Bucket 1: unscored items go to the end
                ),
            )

            # ── User-facing ranking explainer captions ────────────────────────
            any_scored = any(s is not None for _, s in scored_results)

            if any_scored:
                st.caption(
                    "🎯 Results ranked by ingredient similarity to your taste profile. "
                    "Save more recipes to improve the ranking."
                )
            elif has_taste_profile:
                # Profile exists but none of these results had parseable ingredients
                st.caption(
                    "ℹ️ These results don't have ingredient data, "
                    "so ML ranking isn't available here."
                )

            # ── Render one card per result ────────────────────────────────────
            user_pantry = get_pantry()   # Fetch pantry once; reused for every card

            for idx, (meal, score) in enumerate(scored_results):
                render_meal_card(
                    meal,
                    ml_score=score,
                    pantry=pantry_pct(meal, user_pantry),
                    card_key=f"search_{idx}",  # Unique key suffix per card position
                )

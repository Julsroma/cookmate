# NUTRITION HELPER
# ══════════════════════════════════════════════════════════════════════════════

def _fetch_nutrition_robust(meal: dict) -> dict:
    """Fetch per-serving nutrition for any recipe, regardless of source.

    This function implements a three-tier fallback strategy so that nutrition
    data is retrieved as reliably as possible while minimising Spoonacular API
    calls (free tier: 50 points/day).

    Tier 0 — Spoonacular recipe (no API call needed)
    -------------------------------------------------
    Spoonacular results already carry kcal_per_serv / protein_g / carbs_g /
    fat_g inside the meal dict (attached by api_client.py). Return immediately.

    Tier 1 — Title-based Spoonacular lookup  (1 API call)
    -------------------------------------------------------
    Works well for popular TheMealDB dishes whose name Spoonacular recognises
    (e.g. "Spaghetti Bolognese"). fetch_nutrition_by_title() is @st.cache_data
    with a 24-hour TTL, so each unique title is only fetched once per day.

    Tier 2 — Ingredient-parser fallback  (1 API call)
    ---------------------------------------------------
    Used when the title lookup fails.  Sends the raw ingredient list to
    Spoonacular's parseIngredients endpoint, which returns whole-recipe totals.
    We divide by 4 to approximate a per-serving figure.

    ⭐ MEAL PLANNER: called inside the "➕ Add to Meal Planner" button handler
    to ensure every recipe saved to the planner has nutrition data written into
    the `recipes` DB table (kcal_per_serv, protein_g, carbs_g, fat_g).

    Parameters
    ----------
    meal : dict
        A single recipe dict (TheMealDB or Spoonacular schema).

    Returns
    -------
    dict with keys: kcal, protein_g, carbs_g, fat_g.
    All values may be None if every strategy fails (e.g. API quota exhausted).
    """
    # Canonical empty result — returned if all strategies fail
    empty = {"kcal": None, "protein_g": None, "carbs_g": None, "fat_g": None}

    # ── Tier 0: Spoonacular recipes already carry nutrition in the dict ───────
    if meal.get("kcal_per_serv") is not None:
        return {
            "kcal":      meal["kcal_per_serv"],
            "protein_g": meal.get("protein_g"),
            "carbs_g":   meal.get("carbs_g"),
            "fat_g":     meal.get("fat_g"),
        }

    # ── Tier 1: Look up the dish title via Spoonacular complexSearch ──────────
    # extract the title from either schema (TheMealDB uses "strMeal",
    # Spoonacular uses "title")
    title = meal.get("strMeal") or meal.get("title") or ""
    if title:
        try:
            nutrition = fetch_nutrition_by_title(title)
            if nutrition.get("kcal") is not None:
                return nutrition   # Successful lookup — return early
        except Exception:
            pass  # API failure or quota exceeded — fall through to Tier 2

    # ── Tier 2: Ingredient-parser fallback ────────────────────────────────────
    # extract_ingredients() is defined above this function in the file, so it
    # is always available at call time even though this function appears first
    # in the class hierarchy.
    try:
        ingredients = extract_ingredients(meal)
        if ingredients:
            raw = fetch_nutrition_from_ingredients(ingredients)
            if raw.get("kcal") is not None:
                # parseIngredients returns whole-recipe totals, not per-serving.
                # Dividing by 4 is a reasonable approximation for most dishes;
                # the user can override manually in the Nutrition Analytics page.
                return {
                    "kcal":      int(raw["kcal"] / 4),
                    "protein_g": round(raw["protein_g"] / 4, 1) if raw.get("protein_g") else None,
                    "carbs_g":   round(raw["carbs_g"]   / 4, 1) if raw.get("carbs_g")   else None,
                    "fat_g":     round(raw["fat_g"]     / 4, 1) if raw.get("fat_g")     else None,
                }
    except Exception:
        pass  # Any failure (network, parse error, quota) → return empty dict

    return empty



# INGREDIENT EXTRACTOR
# Defined near the top because _fetch_nutrition_robust() (defined next) calls it.
# ══════════════════════════════════════════════════════════════════════════════

def extract_ingredients(meal: dict) -> list[str]:
    """Return a flat list of ingredient strings from any recipe source.

    Why two branches?
    -----------------
    TheMealDB and Spoonacular use completely different JSON schemas:

    • Spoonacular recipes store ready-made strings like "2 cups flour" in a
      private "_ingredients" key that api_client.py attaches to the dict.

    • TheMealDB splits each ingredient across two parallel numbered keys:
        strIngredient1 = "Flour"   strMeasure1 = "2 cups"
        strIngredient2 = "Egg"     strMeasure2 = "1"
        ... up to strIngredient20 / strMeasure20
      We combine them into "2 cups Flour", "1 Egg", etc.

    Parameters
    ----------
    meal : dict
        A single recipe dict as returned by TheMealDB or Spoonacular.

    Returns
    -------
    list[str]
        Human-readable ingredient strings, e.g. ["200g Chicken", "1 Egg"].
        Empty list if no ingredient data is present.

    ⭐ MEAL PLANNER: the ingredient list is also used by _fetch_nutrition_robust()
    as a fallback when Spoonacular can't find a dish by title, which is needed
    before inserting a new recipe into the `recipes` DB table.
    """
    # ── Spoonacular path: ingredients already pre-processed by api_client.py ──
    if meal.get("_ingredients"):
        return [i.strip() for i in meal["_ingredients"] if i.strip()]

    # ── TheMealDB path: reconstruct from parallel numbered key pairs ──────────
    ingredients = []
    for i in range(1, 21):  # TheMealDB supports up to 20 ingredient slots
        name    = (meal.get(f"strIngredient{i}") or "").strip()
        measure = (meal.get(f"strMeasure{i}")    or "").strip()
        if not name:
            # Empty slot means no more ingredients; TheMealDB doesn't always
            # fill all 20 slots, so we can't just continue past a gap.
            continue
        # Prepend the measure if present, e.g. "200g Chicken" vs just "Chicken"
        ingredients.append(f"{measure} {name}" if measure else name)
    return ingredients


